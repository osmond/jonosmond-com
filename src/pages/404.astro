---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found">
  <main>
    <div class="container">
      <span class="code">404</span>
      <h1>Page not found</h1>
      <a href="/">Go home</a>
    </div>
  </main>
</Layout>

<style>
  main {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
  }

  .container {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .code {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  h1 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }

  a {
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.25rem;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
