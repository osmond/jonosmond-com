---
export const prerender = false;

import '../styles/global.css';

Astro.response.headers.set('Cache-Control', 'no-store');

// ─── Redis ────────────────────────────────────────────────────────────────────
const redisUrl   = import.meta.env.UPSTASH_REDIS_REST_URL   as string;
const redisToken = import.meta.env.UPSTASH_REDIS_REST_TOKEN as string;

type PipelineResult = Array<{ result: unknown; error?: string }>;

async function redisPipeline(commands: (string | number)[][]): Promise<unknown[]> {
  const res = await fetch(`${redisUrl}/pipeline`, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${redisToken}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(commands),
  });
  const json = await res.json();
  if (!Array.isArray(json)) return commands.map(() => null);
  return (json as PipelineResult).map(item => item.result ?? null);
}

// ─── 30-day range ─────────────────────────────────────────────────────────────
const N = 30;
const days = Array.from({ length: N }, (_, i) => {
  const d = new Date();
  d.setUTCDate(d.getUTCDate() - (N - 1 - i));
  return d.toISOString().slice(0, 10);
});

// ─── One-shot pipeline ────────────────────────────────────────────────────────
// [0]       pv:total
// [1..N]    pv:day — views per day (30 values)
// [N+1..2N] visitors:day SCARD — unique visitors per day (30 values)
// [2N+1] pages  [2N+2] referrers  [2N+3] countries  [2N+4] cities
// [2N+5] browsers  [2N+6] os  [2N+7] devices  [2N+8] timezones
// [2N+9] colorSchemes  [2N+10] viewports
const results = await redisPipeline([
  ['GET', 'pv:total'],
  ...days.map(d => ['GET',   `pv:day:${d}`]),
  ...days.map(d => ['SCARD', `visitors:day:${d}`]),
  ['ZREVRANGE', 'pages',        0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'referrers',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'countries',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'cities',       0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'browsers',     0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'os',           0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'devices',      0, 4, 'WITHSCORES'],
  ['ZREVRANGE', 'timezones',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'colorSchemes', 0, 4, 'WITHSCORES'],
  ['ZREVRANGE', 'viewports',    0, 4, 'WITHSCORES'],
]);

// ─── Parse ────────────────────────────────────────────────────────────────────
const totalViews = Number(results[0] ?? 0);

const dailyViews = days.map((date, i) => ({
  date,
  views: Number(results[1 + i] ?? 0),
}));

const dailyVisitors = days.map((date, i) => ({
  date,
  visitors: Number(results[1 + N + i] ?? 0),
}));

function parseZSet(raw: unknown) {
  const arr = (raw ?? []) as string[];
  const out: { name: string; count: number }[] = [];
  for (let i = 0; i < arr.length; i += 2) {
    out.push({ name: arr[i]!, count: Number(arr[i + 1]) });
  }
  return out;
}

const topPages      = parseZSet(results[2 * N + 1]);
const topReferrers  = parseZSet(results[2 * N + 2]);
const topCountries  = parseZSet(results[2 * N + 3]);
const topCities     = parseZSet(results[2 * N + 4]);
const topBrowsers   = parseZSet(results[2 * N + 5]);
const topOS         = parseZSet(results[2 * N + 6]);
const topDevices    = parseZSet(results[2 * N + 7]);
const topTimezones  = parseZSet(results[2 * N + 8]);
const colorSchemes  = parseZSet(results[2 * N + 9]);
const topViewports  = parseZSet(results[2 * N + 10]);

// ─── Computed stats ───────────────────────────────────────────────────────────
const todayViews        = dailyViews[N - 1]!.views;
const yesterdayViews    = dailyViews[N - 2]!.views;
const todayVisitors     = dailyVisitors[N - 1]!.visitors;
const yesterdayVisitors = dailyVisitors[N - 2]!.visitors;
const sevenDayViews     = dailyViews.slice(N - 7).reduce((s, d) => s + d.views, 0);
const lastWeekViews     = dailyViews.slice(N - 14, N - 7).reduce((s, d) => s + d.views, 0);

// ─── Week-over-week deltas ────────────────────────────────────────────────────
type Delta = { pct: number; positive: boolean } | null;

function calcDelta(curr: number, prev: number): Delta {
  if (prev === 0) return null;
  const pct = Math.round(((curr - prev) / prev) * 100);
  return { pct, positive: pct >= 0 };
}

const delta7Day    = calcDelta(sevenDayViews, lastWeekViews);
const deltaToday   = calcDelta(todayViews, yesterdayViews);
const deltaVisitor = calcDelta(todayVisitors, yesterdayVisitors);

// ─── Chart helpers ────────────────────────────────────────────────────────────
const maxViews    = Math.max(...dailyViews.map(d => d.views), 1);
const maxVisitors = Math.max(...dailyVisitors.map(d => d.visitors), 1);

function barH(val: number, max: number) {
  return val > 0 ? Math.max((val / max) * 100, 3).toFixed(1) : '0';
}

function fmtDate(iso: string) {
  const [, m, d] = iso.split('-');
  return `${parseInt(m!)}/${parseInt(d!)}`;
}

function fmtNum(n: number) { return n.toLocaleString('en-US'); }

function flag(code: string): string {
  if (code.length !== 2) return '';
  return String.fromCodePoint(
    0x1F1E6 + code.toUpperCase().charCodeAt(0) - 65,
    0x1F1E6 + code.toUpperCase().charCodeAt(1) - 65,
  );
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Analytics</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="page">

      <header class="header">
        <a href="/" class="back-link">&larr; jonosmond.com</a>
        <div class="header-row">
          <h1>Analytics</h1>
          <div class="header-actions">
            <button id="opt-out-btn" class="opt-btn"></button>
            <a href="/analytics" class="refresh" onclick="event.preventDefault();location.reload()">Refresh</a>
          </div>
        </div>
      </header>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="card">
          <div class="stat-value">{fmtNum(totalViews)}</div>
          <div class="stat-label">All-time views</div>
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(sevenDayViews)}</div>
          <div class="stat-label">Last 7 days</div>
          {delta7Day && (
            <div class={`stat-delta ${delta7Day.positive ? 'pos' : 'neg'}`}>
              {delta7Day.positive ? '+' : ''}{delta7Day.pct}% vs prev week
            </div>
          )}
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(todayViews)}</div>
          <div class="stat-label">Today's views</div>
          {deltaToday && (
            <div class={`stat-delta ${deltaToday.positive ? 'pos' : 'neg'}`}>
              {deltaToday.positive ? '+' : ''}{deltaToday.pct}% vs yesterday
            </div>
          )}
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(todayVisitors)}</div>
          <div class="stat-label">Today's visitors</div>
          {deltaVisitor && (
            <div class={`stat-delta ${deltaVisitor.positive ? 'pos' : 'neg'}`}>
              {deltaVisitor.positive ? '+' : ''}{deltaVisitor.pct}% vs yesterday
            </div>
          )}
        </div>
      </div>

      <!-- 30-day chart with views / visitors toggle -->
      <div class="card chart-card">
        <div class="chart-header">
          <h2 class="section-title">Last 30 days</h2>
          <div class="chart-toggle" role="group" aria-label="Chart metric">
            <button class="toggle-btn active" data-mode="views">Views</button>
            <button class="toggle-btn" data-mode="visitors">Visitors</button>
          </div>
        </div>
        <div class="chart" id="chart">
          {dailyViews.map((day, i) => {
            const vh = barH(day.views, maxViews);
            const uh = barH(dailyVisitors[i]!.visitors, maxVisitors);
            const showLabel = i % 5 === 0 || i === N - 1;
            return (
              <div class="bar-wrap"
                data-vh={vh}
                data-uh={uh}
                data-vc={day.views}
                data-uc={dailyVisitors[i]!.visitors}
                data-date={day.date}
                title={`${fmtNum(day.views)} views · ${day.date}`}>
                <div class="bar" style={`height:${vh}%`}></div>
                <span class="bar-label">{showLabel ? fmtDate(day.date) : ''}</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Pages + Sources -->
      <div class={`bottom-grid${topReferrers.length === 0 ? ' single' : ''}`}>
        {topPages.length > 0 && (
          <div class="card">
            <h2 class="section-title">Top pages</h2>
            <table class="data-table">
              <thead><tr><th>Page</th><th>Views</th></tr></thead>
              <tbody>
                {topPages.map(p => (
                  <tr>
                    <td class="mono">{p.name}</td>
                    <td class="num">{fmtNum(p.count)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        {topReferrers.length > 0 && (
          <div class="card">
            <h2 class="section-title">Top sources</h2>
            <table class="data-table">
              <thead><tr><th>Source</th><th>Views</th></tr></thead>
              <tbody>
                {topReferrers.map(r => (
                  <tr>
                    <td class={r.name === 'Direct' ? 'muted' : ''}>{r.name}</td>
                    <td class="num">{fmtNum(r.count)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <!-- Countries + Cities -->
      {(topCountries.length > 0 || topCities.length > 0) && (
        <div class="two-col">
          {topCountries.length > 0 && (
            <div class="card">
              <h2 class="section-title">Countries</h2>
              <div class="countries">
                {topCountries.map(c => (
                  <div class="country-row">
                    <span class="country-flag">{flag(c.name)}</span>
                    <span class="country-code">{c.name}</span>
                    <div class="country-bar-wrap">
                      <div
                        class="country-bar"
                        style={`width:${((c.count / topCountries[0]!.count) * 100).toFixed(1)}%`}
                      ></div>
                    </div>
                    <span class="country-count">{fmtNum(c.count)}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
          {topCities.length > 0 && (
            <div class="card">
              <h2 class="section-title">Cities</h2>
              <table class="data-table">
                <thead><tr><th>City</th><th>Views</th></tr></thead>
                <tbody>
                  {topCities.map(c => (
                    <tr>
                      <td>{c.name}</td>
                      <td class="num">{fmtNum(c.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

      <!-- Devices + Browsers + OS -->
      {(topDevices.length > 0 || topBrowsers.length > 0 || topOS.length > 0) && (
        <div class="three-col">
          {topDevices.length > 0 && (
            <div class="card">
              <h2 class="section-title">Devices</h2>
              <table class="data-table">
                <thead><tr><th>Type</th><th>Views</th></tr></thead>
                <tbody>
                  {topDevices.map(d => (
                    <tr>
                      <td>{d.name}</td>
                      <td class="num">{fmtNum(d.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          {topBrowsers.length > 0 && (
            <div class="card">
              <h2 class="section-title">Browsers</h2>
              <table class="data-table">
                <thead><tr><th>Browser</th><th>Views</th></tr></thead>
                <tbody>
                  {topBrowsers.map(b => (
                    <tr>
                      <td>{b.name}</td>
                      <td class="num">{fmtNum(b.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          {topOS.length > 0 && (
            <div class="card">
              <h2 class="section-title">Operating Systems</h2>
              <table class="data-table">
                <thead><tr><th>OS</th><th>Views</th></tr></thead>
                <tbody>
                  {topOS.map(o => (
                    <tr>
                      <td>{o.name}</td>
                      <td class="num">{fmtNum(o.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

      <!-- Timezones + Color scheme + Viewport -->
      {(topTimezones.length > 0 || colorSchemes.length > 0 || topViewports.length > 0) && (
        <div class="three-col">
          {topTimezones.length > 0 && (
            <div class="card">
              <h2 class="section-title">Timezones</h2>
              <table class="data-table">
                <thead><tr><th>Timezone</th><th>Views</th></tr></thead>
                <tbody>
                  {topTimezones.map(t => (
                    <tr>
                      <td class="mono" style="font-size:0.75rem">{t.name}</td>
                      <td class="num">{fmtNum(t.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          {colorSchemes.length > 0 && (
            <div class="card">
              <h2 class="section-title">Color scheme</h2>
              <table class="data-table">
                <thead><tr><th>Scheme</th><th>Views</th></tr></thead>
                <tbody>
                  {colorSchemes.map(s => (
                    <tr>
                      <td>{s.name}</td>
                      <td class="num">{fmtNum(s.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          {topViewports.length > 0 && (
            <div class="card">
              <h2 class="section-title">Viewport</h2>
              <table class="data-table">
                <thead><tr><th>Size</th><th>Views</th></tr></thead>
                <tbody>
                  {topViewports.map(v => (
                    <tr>
                      <td>{v.name}</td>
                      <td class="num">{fmtNum(v.count)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

    </div>

    <script>
      // ── Opt-out toggle ──────────────────────────────────────────────────────
      const OPT_OUT_KEY = 'analytics_opt_out';
      const btn = document.getElementById('opt-out-btn') as HTMLButtonElement | null;
      function updateBtn() {
        if (!btn) return;
        const excluded = localStorage.getItem(OPT_OUT_KEY) === '1';
        btn.textContent = excluded ? 'You are excluded from data' : 'Exclude me from data';
        btn.classList.toggle('excluded', excluded);
      }
      updateBtn();
      btn?.addEventListener('click', () => {
        const excluded = localStorage.getItem(OPT_OUT_KEY) === '1';
        if (excluded) {
          localStorage.removeItem(OPT_OUT_KEY);
        } else {
          localStorage.setItem(OPT_OUT_KEY, '1');
        }
        updateBtn();
      });

      const chart = document.getElementById('chart');
      const btns  = document.querySelectorAll<HTMLButtonElement>('.toggle-btn');
      if (chart && btns.length) {
        btns.forEach(btn => {
          btn.addEventListener('click', () => {
            const mode = btn.dataset.mode as 'views' | 'visitors';
            btns.forEach(b => b.classList.toggle('active', b === btn));
            chart.querySelectorAll<HTMLElement>('.bar-wrap').forEach(wrap => {
              const bar = wrap.querySelector<HTMLElement>('.bar')!;
              bar.style.height = (mode === 'visitors' ? wrap.dataset.uh : wrap.dataset.vh) + '%';
              const count = mode === 'visitors' ? wrap.dataset.uc : wrap.dataset.vc;
              wrap.title = `${Number(count).toLocaleString()} ${mode} · ${wrap.dataset.date}`;
            });
          });
        });
      }
    </script>
  </body>
</html>

<style>
  body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Header ── */
  .header h1 {
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    letter-spacing: -0.02em;
  }

  .updated {
    color: var(--color-muted);
    font-size: 0.8125rem;
    margin: 0 0 0.5rem;
  }

  a.refresh { color: var(--color-accent); text-decoration: none; font-size: 0.8125rem; }
  a.refresh:hover { text-decoration: underline; }

  /* ── Back link ── */
  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 0.1s;
  }
  .back-link:hover { color: var(--color-text); }

  /* ── Header row ── */
  .header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* ── Opt-out button ── */
  .opt-btn {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 0.75rem;
    padding: 0.25rem 0.625rem;
    cursor: pointer;
    transition: border-color 0.1s, color 0.1s;
  }
  .opt-btn:hover { border-color: var(--color-border-highlight); color: var(--color-text); }
  .opt-btn.excluded { border-color: #6aaf82; color: #6aaf82; }

  /* ── Stats grid ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 600px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ── Card ── */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    color: var(--color-muted);
    font-size: 0.8125rem;
    margin-top: 0.375rem;
  }

  .stat-delta {
    font-size: 0.6875rem;
    font-weight: 500;
    margin-top: 0.3rem;
  }

  .stat-delta.pos { color: #6aaf82; }
  .stat-delta.neg { color: var(--color-accent); }

  /* ── Section title ── */
  .section-title {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }

  /* ── Chart ── */
  .chart-card { padding-bottom: 1rem; }

  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .chart-header .section-title { margin: 0; }

  .chart-toggle {
    display: flex;
    gap: 2px;
    background: var(--color-border);
    border-radius: 6px;
    padding: 2px;
  }

  .toggle-btn {
    border: none;
    background: transparent;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.1s, color 0.1s;
  }

  .toggle-btn.active {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .toggle-btn:hover:not(.active) { color: var(--color-text); }

  .chart {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 8rem;
  }

  .bar-wrap {
    flex: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    cursor: default;
  }

  .bar {
    width: 100%;
    background: var(--color-accent);
    border-radius: 2px 2px 0 0;
    opacity: 0.7;
    transition: opacity 0.1s, height 0.2s ease;
    min-height: 0;
  }

  .bar-wrap:hover .bar { opacity: 1; }

  .bar-label {
    display: block;
    font-size: 0.5rem;
    color: var(--color-muted);
    margin-top: 0.375rem;
    white-space: nowrap;
    overflow: hidden;
    text-align: center;
    max-width: 100%;
  }

  /* ── Bottom grid: pages + sources ── */
  .bottom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .bottom-grid.single { grid-template-columns: 1fr; }

  @media (max-width: 600px) {
    .bottom-grid { grid-template-columns: 1fr; }
  }

  /* ── Two-col + three-col grids ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .three-col {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .two-col   { grid-template-columns: 1fr; }
    .three-col { grid-template-columns: 1fr; }
  }

  /* ── Data table ── */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .data-table th {
    text-align: left;
    font-weight: 500;
    color: var(--color-muted);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0 0 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .data-table th:last-child,
  .data-table td:last-child { text-align: right; }

  .data-table td {
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .data-table tr:last-child td { border-bottom: none; }

  .mono {
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 0.8125rem;
  }

  .num {
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }

  .muted { color: var(--color-muted); }

  /* ── Countries ── */
  .countries {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .country-row {
    display: grid;
    grid-template-columns: 1.5rem 2.5rem 1fr 2.5rem;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
  }

  .country-flag { font-size: 1rem; line-height: 1; }
  .country-code { color: var(--color-muted); font-size: 0.75rem; }

