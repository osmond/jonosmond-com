    <script define:vars={{ dailyViews, dailyVisitors, topPages, topReferrers, topCountries, topCities, sevenDayViews, thirtyDayViews, totalViews, dailyAvg, thirtyDayVisitors }}>
      // ── CSV Export ─────────────────────────────────────────────────────────
      function downloadCSV(filename: string, rows: string[][]) {
        const csv = rows.map(r => r.map(c => `"${String(c).replace(/"/g, '""')}"`).join(',')).join('\n');
        const blob = new Blob([csv], { type: 'text/csv' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = filename;
        a.click();
        URL.revokeObjectURL(a.href);
      }

      document.getElementById('export-btn')?.addEventListener('click', () => {
        const rows: string[][] = [
          ['Date', 'Views', 'Visitors'],
          ...(dailyViews as {date:string;views:number}[]).map((d, i) => [
            d.date,
            String(d.views),
            String((dailyVisitors as {date:string;visitors:number}[])[i]?.visitors ?? 0),
          ]),
          [],
          ['Metric', 'Value'],
          ['Total views', String(totalViews)],
          ['7-day views', String(sevenDayViews)],
          ['30-day views', String(thirtyDayViews)],
          ['30-day visitors (est)', String(thirtyDayVisitors)],
          ['Daily avg (30d)', String(dailyAvg)],
          [],
          ['Page', 'Views'],
          ...(topPages as {name:string;count:number}[]).map(p => [p.name, String(p.count)]),
          [],
          ['Source', 'Views'],
          ...(topReferrers as {name:string;count:number}[]).map(r => [r.name, String(r.count)]),
          [],
          ['Country', 'Views'],
          ...(topCountries as {name:string;count:number}[]).map(c => [c.name, String(c.count)]),
          [],
          ['City', 'Views'],
          ...(topCities as {name:string;count:number}[]).map(c => [c.name, String(c.count)]),
        ];
        downloadCSV(`analytics-${new Date().toISOString().slice(0,10)}.csv`, rows);
      });
    </script>

    <script>
      // ── Opt-out toggle ──────────────────────────────────────────────────────
      const OPT_OUT_KEY = 'analytics_opt_out';
      const btn = document.getElementById('opt-out-btn') as HTMLButtonElement | null;
      function updateBtn() {
        if (!btn) return;
        const excluded = localStorage.getItem(OPT_OUT_KEY) === '1';
        btn.textContent = excluded ? 'Opted out ✓' : 'Opt out';
        btn.classList.toggle('excluded', excluded);
      }
      updateBtn();
      // Update feed empty message for opted-out users on first load
      const feedEmptyMsg = document.getElementById('feed-empty-msg');
      if (feedEmptyMsg && localStorage.getItem(OPT_OUT_KEY) === '1') {
        feedEmptyMsg.textContent = "You're excluded from tracking. Other visitors will appear here.";
      }
      btn?.addEventListener('click', () => {
        const excluded = localStorage.getItem(OPT_OUT_KEY) === '1';
        if (excluded) {
          localStorage.removeItem(OPT_OUT_KEY);
        } else {
          localStorage.setItem(OPT_OUT_KEY, '1');
        }
        updateBtn();
      });

      // ── Chart toggle (views / visitors) + avg-line sync ───────────────────
      const chart = document.getElementById('chart') as HTMLElement | null;
      const avgLine = document.getElementById('avg-line') as HTMLElement | null;
      const btns  = document.querySelectorAll<HTMLButtonElement>('.toggle-btn');
      let currentMode: 'views' | 'visitors' = 'views';
      let currentRange: '7' | '30' | '90' = '30';

      function getBarHeight(wrap: HTMLElement): string {
        const rKey = currentRange === '30' ? '' : currentRange; // '' = 30 (default dataset key)
        const prefix = currentMode === 'views' ? 'vh' : 'uh';
        const key = rKey ? `${prefix}${rKey}` : prefix;
        return wrap.dataset[key] ?? '0';
      }

      function applyRange(range: '7' | '30' | '90') {
        currentRange = range;
        const rangeMap: Record<string, string> = { '7': '7', '30': '30', '90': '90' };
        const titleEl = document.getElementById('chart-title');
        if (titleEl) titleEl.textContent = `Last ${rangeMap[range]} days`;
        chart?.querySelectorAll<HTMLElement>('.bar-wrap').forEach(wrap => {
          const in7  = 'in7'  in wrap.dataset;
          const in30 = 'in30' in wrap.dataset;
          const show = range === '90' || (range === '30' && in30) || (range === '7' && in7);
          wrap.style.display = show ? '' : 'none';
          const bar = wrap.querySelector<HTMLElement>('.bar')!;
          bar.style.height = getBarHeight(wrap) + '%';
          const count = currentMode === 'visitors' ? wrap.dataset.uc : wrap.dataset.vc;
          if (show) wrap.title = `${Number(count).toLocaleString()} ${currentMode} · ${wrap.dataset.date}`;
        });
        // Update avg line position
        if (avgLine && chart) {
          const modeKey = currentMode === 'views' ? 'Vh' : 'Uh';
          const rangeKey = range === '30' ? 'avg' : range === '7' ? 'avg7' : 'avg90';
          const h = chart.dataset[`${rangeKey}${modeKey}`] ?? '0';
          avgLine.style.bottom = h + '%';
        }
        // Update range button state
        document.querySelectorAll<HTMLElement>('.range-btn').forEach(b =>
          b.classList.toggle('active', b.dataset.range === range)
        );
      }

      if (chart && btns.length) {
        btns.forEach(btn => {
          btn.addEventListener('click', () => {
            currentMode = btn.dataset.mode as 'views' | 'visitors';
            btns.forEach(b => b.classList.toggle('active', b === btn));
            chart.querySelectorAll<HTMLElement>('.bar-wrap').forEach(wrap => {
              if (wrap.style.display === 'none') return;
              const bar = wrap.querySelector<HTMLElement>('.bar')!;
              bar.style.height = getBarHeight(wrap) + '%';
              const count = currentMode === 'visitors' ? wrap.dataset.uc : wrap.dataset.vc;
              wrap.title = `${Number(count).toLocaleString()} ${currentMode} · ${wrap.dataset.date}`;
            });
            // Shift avg line
            if (avgLine && chart) {
              const modeKey = currentMode === 'views' ? 'Vh' : 'Uh';
              const rangeKey = currentRange === '30' ? 'avg' : currentRange === '7' ? 'avg7' : 'avg90';
              avgLine.style.bottom = (chart.dataset[`${rangeKey}${modeKey}`] ?? '0') + '%';
            }
          });
        });
      }

      document.querySelectorAll<HTMLButtonElement>('.range-btn').forEach(btn => {
        btn.addEventListener('click', () => applyRange(btn.dataset.range as '7' | '30' | '90'));
      });

      // ── Hourly chart: shift labels from UTC to viewer's local time ────────
      const offsetHours = -(new Date().getTimezoneOffset() / 60);
      const grid = document.getElementById('hourly-grid');
      if (grid && offsetHours !== 0) {
        const cells = Array.from(grid.querySelectorAll<HTMLElement>('.hour-cell'));
        // Reorder DOM nodes by local hour
        const sorted = [...cells].sort((a, b) => {
          const la = (Number(a.dataset.utcHour) + offsetHours + 24) % 24;
          const lb = (Number(b.dataset.utcHour) + offsetHours + 24) % 24;
          return la - lb;
        });
        sorted.forEach((cell, i) => {
          const utcH = Number(cell.dataset.utcHour);
          const localH = (utcH + offsetHours + 24) % 24;
          const label = cell.querySelector<HTMLElement>('.hour-label')!;
          label.textContent = localH % 6 === 0 ? `${localH}h` : '';
          const sign = offsetHours >= 0 ? '+' : '';
          cell.title = cell.title.replace(/^\d+:00 UTC/, `${localH}:00 local (UTC${sign}${offsetHours})`);
          grid.appendChild(cell);
        });
      }

      // ── Relative timestamps in recent feed ───────────────────────────────
      function relativeTime(iso: string): string {
        const diff = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
        if (diff < 60)   return `${diff}s ago`;
        if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
        if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
        return `${Math.floor(diff / 86400)}d ago`;
      }
      function updateFeedTimes() {
        document.querySelectorAll<HTMLElement>('.feed-time[data-ts]').forEach(el => {
          el.textContent = relativeTime(el.dataset.ts!);
        });
      }
      updateFeedTimes();

      // ── Recent feed auto-poll every 30s ───────────────────────────────────
      function countryFlag(code: string): string {
        if (code.length !== 2) return '';
        return String.fromCodePoint(
          0x1F1E6 + code.toUpperCase().charCodeAt(0) - 65,
          0x1F1E6 + code.toUpperCase().charCodeAt(1) - 65,
        );
      }
      function renderFeed(events: Array<{ts:string;page:string;country:string;referrer:string;device:string}>) {
        const feed = document.getElementById('recent-feed');
        if (!feed) return;
        if (!events.length) {
          const isOptOut = localStorage.getItem(OPT_OUT_KEY) === '1';
          feed.innerHTML = `<p class="feed-empty" id="feed-empty-msg">${isOptOut ? "You're excluded from tracking. Other visitors will appear here." : 'No visits recorded yet.'}</p>`;
          return;
        }
        feed.innerHTML = `<div class="feed-list">${events.map(e => `
          <div class="feed-row">
            <span class="feed-page mono">${e.page}</span>
            <span class="feed-meta">${countryFlag(e.country)} ${e.country}${e.referrer && e.referrer !== 'Direct' ? ` · <span class="feed-ref">${e.referrer}</span>` : ''} · ${e.device}</span>
            <span class="feed-time" data-ts="${e.ts}">${relativeTime(e.ts)}</span>
          </div>`).join('')}</div>`;
      }

      const dot = document.getElementById('feed-dot');
      setInterval(async () => {
        try {
          const res = await fetch('/api/recent');
          if (!res.ok) return;
          const events = await res.json() as Array<{ts:string;page:string;country:string;referrer:string;device:string}>;
          renderFeed(events);
          if (dot) { dot.classList.add('pulse'); setTimeout(() => dot.classList.remove('pulse'), 600); }
        } catch { /* ignore */ }
      }, 30_000);

      // tick relative times every minute
      setInterval(updateFeedTimes, 60_000);
    </script>
  </body>
</html>

