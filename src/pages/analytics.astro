---
export const prerender = false;

import '../styles/global.css';

// ─── Redis helper ─────────────────────────────────────────────────────────────
const redisUrl = import.meta.env.UPSTASH_REDIS_REST_URL as string;
const redisToken = import.meta.env.UPSTASH_REDIS_REST_TOKEN as string;

type PipelineResult = Array<{ result: unknown; error?: string }>;

async function redisPipeline(commands: (string | number)[][]): Promise<unknown[]> {
  const res = await fetch(`${redisUrl}/pipeline`, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${redisToken}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(commands),
  });
  const json = await res.json();
  if (!Array.isArray(json)) {
    // Return nulls so the page still renders with zeros
    return commands.map(() => null);
  }
  return (json as PipelineResult).map(item => item.result ?? null);
}

// ─── Build 30-day date range ──────────────────────────────────────────────────
const N = 30;
const days = Array.from({ length: N }, (_, i) => {
  const d = new Date();
  d.setUTCDate(d.getUTCDate() - (N - 1 - i));
  return d.toISOString().slice(0, 10);
});

// ─── Fetch all data in one pipeline ──────────────────────────────────────────
const results = await redisPipeline([
  ['GET', 'pv:total'],
  ...days.map(d => ['GET', `pv:day:${d}`]),
  ...days.map(d => ['SCARD', `visitors:day:${d}`]),
  ['ZREVRANGE', 'pages', 0, 9, 'WITHSCORES'],
]);

// ─── Parse results ────────────────────────────────────────────────────────────
const totalViews = Number(results[0] ?? 0);

const dailyViews = days.map((date, i) => ({
  date,
  views: Number(results[1 + i] ?? 0),
}));

const dailyVisitors = days.map((date, i) => ({
  date,
  visitors: Number(results[1 + N + i] ?? 0),
}));

const pagesRaw = (results[1 + N * 2] ?? []) as string[];
const topPages: { path: string; views: number }[] = [];
for (let i = 0; i < pagesRaw.length; i += 2) {
  topPages.push({ path: pagesRaw[i]!, views: Number(pagesRaw[i + 1]) });
}

// ─── Computed stats ───────────────────────────────────────────────────────────
const todayViews    = dailyViews[N - 1]!.views;
const todayVisitors = dailyVisitors[N - 1]!.visitors;
const sevenDayViews = dailyViews.slice(-7).reduce((s, d) => s + d.views, 0);

// ─── Chart (last 14 days) ─────────────────────────────────────────────────────
const chartData = dailyViews.slice(-14);
const maxVal    = Math.max(...chartData.map(d => d.views), 1);

function fmtDate(iso: string) {
  const [, m, d] = iso.split('-');
  return `${parseInt(m!)}/${parseInt(d!)}`;
}

function fmtNum(n: number) {
  return n.toLocaleString('en-US');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Analytics</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="page">

      <header class="header">
        <h1>Analytics</h1>
        <p class="updated">
          Updated just now &middot;
          <a href="/analytics" class="refresh">Refresh</a>
        </p>
      </header>

      <!-- Stats grid -->
      <div class="stats-grid">
        <div class="card">
          <div class="stat-value">{fmtNum(totalViews)}</div>
          <div class="stat-label">All-time views</div>
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(sevenDayViews)}</div>
          <div class="stat-label">Last 7 days</div>
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(todayViews)}</div>
          <div class="stat-label">Today's views</div>
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(todayVisitors)}</div>
          <div class="stat-label">Today's visitors</div>
        </div>
      </div>

      <!-- Bar chart: last 14 days -->
      <div class="card chart-card">
        <h2 class="section-title">Last 14 days</h2>
        <div class="chart">
          {chartData.map(day => (
            <div class="bar-wrap" title={`${fmtNum(day.views)} views · ${day.date}`}>
              <div
                class="bar"
                style={`height: ${day.views > 0 ? Math.max((day.views / maxVal) * 100, 4) : 0}%`}
              ></div>
              <span class="bar-label">{fmtDate(day.date)}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Top pages -->
      {topPages.length > 0 && (
        <div class="card">
          <h2 class="section-title">Top pages</h2>
          <table class="pages-table">
            <thead>
              <tr>
                <th>Page</th>
                <th>Views</th>
              </tr>
            </thead>
            <tbody>
              {topPages.map(p => (
                <tr>
                  <td class="path">{p.path}</td>
                  <td class="count">{fmtNum(p.views)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

    </div>
  </body>
</html>

<style>
  body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Header ── */
  .header h1 {
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    letter-spacing: -0.02em;
  }

  .updated {
    color: var(--color-muted);
    font-size: 0.8125rem;
    margin: 0 0 0.5rem;
  }

  a.refresh {
    color: var(--color-accent);
    text-decoration: none;
  }
  a.refresh:hover {
    text-decoration: underline;
  }

  /* ── Stats grid ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 600px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Card ── */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    color: var(--color-muted);
    font-size: 0.8125rem;
    margin-top: 0.375rem;
  }

  /* ── Section title ── */
  .section-title {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }

  /* ── Bar chart ── */
  .chart-card {
    padding-bottom: 1rem;
  }

  .chart {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 8rem;
  }

  .bar-wrap {
    flex: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    cursor: default;
  }

  .bar {
    width: 100%;
    background: var(--color-accent);
    border-radius: 2px 2px 0 0;
    opacity: 0.75;
    transition: opacity 0.1s;
    min-height: 0;
  }

  .bar-wrap:hover .bar {
    opacity: 1;
  }

  .bar-label {
    display: block;
    font-size: 0.5625rem;
    color: var(--color-muted);
    margin-top: 0.375rem;
    white-space: nowrap;
    overflow: hidden;
    text-align: center;
    max-width: 100%;
  }

  /* ── Top pages table ── */
  .pages-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .pages-table th {
    text-align: left;
    font-weight: 500;
    color: var(--color-muted);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0 0 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .pages-table th:last-child,
  .pages-table td:last-child {
    text-align: right;
  }

  .pages-table td {
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pages-table tr:last-child td {
    border-bottom: none;
  }

  .path {
    font-family: ui-monospace, 'Menlo', monospace;
    font-size: 0.8125rem;
  }

  .count {
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }
</style>
