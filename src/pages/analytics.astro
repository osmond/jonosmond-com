---
export const prerender = false;

import '../styles/global.css';

Astro.response.headers.set('Cache-Control', 'no-store');

// ─── Password gate ────────────────────────────────────────────────────────────
const analyticsPassword = (import.meta.env.ANALYTICS_PASSWORD as string | undefined)?.trim();
if (analyticsPassword) {
  const supplied = (Astro.url.searchParams.get('key') ?? Astro.cookies.get('analytics_key')?.value ?? '').trim();
  if (supplied !== analyticsPassword) {
    // Set cookie on successful POST submission
    if (Astro.request.method === 'POST') {
      const form = await Astro.request.formData();
      const attempt = (form.get('key')?.toString() ?? '').trim();
      if (attempt === analyticsPassword) {
        Astro.cookies.set('analytics_key', analyticsPassword, {
          httpOnly: true,
          secure: true,
          sameSite: 'strict',
          maxAge: 60 * 60 * 24 * 30, // 30 days
          path: '/analytics',
        });
        return Astro.redirect('/analytics');
      }
    }
    return new Response(
      `<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Analytics</title><style>*{box-sizing:border-box}body{margin:0;min-height:100svh;display:grid;place-items:center;background:#0f0f0f;font-family:system-ui,sans-serif;color:#f5f4f0}form{display:flex;flex-direction:column;gap:1rem;width:min(320px,90vw)}input{background:#161616;border:1px solid rgba(245,244,240,0.1);border-radius:8px;padding:.75rem 1rem;color:#f5f4f0;font-size:1rem;outline:none}input:focus{border-color:rgba(196,107,75,0.6)}button{background:#c46b4b;border:none;border-radius:8px;padding:.75rem 1rem;color:#0f0f0f;font-size:1rem;font-weight:600;cursor:pointer}@media(prefers-color-scheme:light){body{background:#f5f0e8;color:#1a1714}input{background:#ede8df;border-color:rgba(26,23,20,0.1);color:#1a1714}}</style></head><body><form method="POST"><input type="password" name="key" placeholder="Password" autofocus autocomplete="current-password" /><button type="submit">View analytics</button></form></body></html>`,
      { status: 401, headers: { 'Content-Type': 'text/html;charset=utf-8', 'Cache-Control': 'no-store' } },
    );
  }
}

// ─── Redis ────────────────────────────────────────────────────────────────────
const redisUrl   = import.meta.env.UPSTASH_REDIS_REST_URL   as string;
const redisToken = import.meta.env.UPSTASH_REDIS_REST_TOKEN as string;

type PipelineResult = Array<{ result: unknown; error?: string }>;

async function redisPipeline(commands: (string | number)[][]): Promise<unknown[]> {
  const res = await fetch(`${redisUrl}/pipeline`, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${redisToken}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(commands),
  });
  const json = await res.json();
  if (!Array.isArray(json)) return commands.map(() => null);
  return (json as PipelineResult).map(item => item.result ?? null);
}

// ─── 30-day range ─────────────────────────────────────────────────────────────
const N = 90;
const days = Array.from({ length: N }, (_, i) => {
  const d = new Date();
  d.setUTCDate(d.getUTCDate() - (N - 1 - i));
  return d.toISOString().slice(0, 10);
});

// ─── One-shot pipeline ────────────────────────────────────────────────────────
// [0]       pv:total
// [1..N]    pv:day — views per day (30 values)
// [N+1..2N] visitors:day SCARD — unique visitors per day (30 values)
// [2N+1] pages  [2N+2] referrers  [2N+3] countries  [2N+4] cities
// [2N+5] browsers  [2N+6] os  [2N+7] devices  [2N+8] timezones
// [2N+9] colorSchemes  [2N+10] viewports
// [2N+11] scroll_depth  [2N+12] outbound_clicks
// [2N+13] visitor_type  [2N+14] time_on_page  [2N+15] time_total_secs  [2N+16] time_total_sessions
// [2N+17] pv:hourly  [2N+18] languages  [2N+19] entry_pages
// [2N+20] utm_source  [2N+21] utm_medium  [2N+22] utm_campaign
// [2N+23] recent_events
// [2N+24] sessions_total  [2N+25] sessions_engaged
// [2N+26] exit_pages  [2N+27] cwv:LCP  [2N+28] cwv:CLS  [2N+29] cwv:INP
const results = await redisPipeline([
  ['GET', 'pv:total'],
  ...days.map(d => ['GET',   `pv:day:${d}`]),
  ...days.map(d => ['SCARD', `visitors:day:${d}`]),
  ['ZREVRANGE', 'pages',        0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'referrers',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'countries',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'cities',       0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'browsers',     0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'os',           0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'devices',      0, 4, 'WITHSCORES'],
  ['ZREVRANGE', 'timezones',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'colorSchemes', 0, 4, 'WITHSCORES'],
  ['ZREVRANGE', 'viewports',    0, 4, 'WITHSCORES'],
  ['ZREVRANGE', 'scroll_depth',    0, -1, 'WITHSCORES'],
  ['ZREVRANGE', 'outbound_clicks', 0,  9, 'WITHSCORES'],
  ['ZREVRANGE', 'visitor_type',  0, -1, 'WITHSCORES'],
  ['ZREVRANGE', 'time_on_page',  0, -1, 'WITHSCORES'],
  ['GET', 'time_total_secs'],
  ['GET', 'time_total_sessions'],
  ['HGETALL', 'pv:hourly'],
  ['ZREVRANGE', 'languages',    0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'entry_pages',  0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'utm_source',   0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'utm_medium',   0, 9, 'WITHSCORES'],
  ['ZREVRANGE', 'utm_campaign', 0, 9, 'WITHSCORES'],
  ['LRANGE',   'recent_events', 0, 19],
  ['GET',      'sessions_total'],
  ['GET',      'sessions_engaged'],
  ['ZREVRANGE','exit_pages',    0, 9, 'WITHSCORES'],
  ['HGETALL',  'cwv:LCP'],
  ['HGETALL',  'cwv:CLS'],
  ['HGETALL',  'cwv:INP'],
]);

// ─── Parse ────────────────────────────────────────────────────────────────────
const totalViews = Number(results[0] ?? 0);

const dailyViews = days.map((date, i) => ({
  date,
  views: Number(results[1 + i] ?? 0),
}));

const dailyVisitors = days.map((date, i) => ({
  date,
  visitors: Number(results[1 + N + i] ?? 0),
}));

function parseZSet(raw: unknown) {
  const arr = (raw ?? []) as string[];
  const out: { name: string; count: number }[] = [];
  for (let i = 0; i < arr.length; i += 2) {
    out.push({ name: arr[i]!, count: Number(arr[i + 1]) });
  }
  return out;
}

const topPages      = parseZSet(results[2 * N + 1]);
const topReferrers  = parseZSet(results[2 * N + 2]);
const topCountries  = parseZSet(results[2 * N + 3]);
const topCities     = parseZSet(results[2 * N + 4]);
const topBrowsers   = parseZSet(results[2 * N + 5]);
const topOS         = parseZSet(results[2 * N + 6]);
const topDevices    = parseZSet(results[2 * N + 7]);
const topTimezones  = parseZSet(results[2 * N + 8]);
const colorSchemes  = parseZSet(results[2 * N + 9]);
const topViewports     = parseZSet(results[2 * N + 10]);
const rawScrollDepth   = parseZSet(results[2 * N + 11]);
const topClicks        = parseZSet(results[2 * N + 12]);
const visitorTypes     = parseZSet(results[2 * N + 13]);
const timeOnPageBkts   = parseZSet(results[2 * N + 14]);
const totalTimeSecs    = Number(results[2 * N + 15] ?? 0);
const totalTimeSessions= Number(results[2 * N + 16] ?? 0);
const topLanguages     = parseZSet(results[2 * N + 18]);
const topEntryPages    = parseZSet(results[2 * N + 19]);
const topUtmSource     = parseZSet(results[2 * N + 20]);
const topUtmMedium     = parseZSet(results[2 * N + 21]);
const topUtmCampaign   = parseZSet(results[2 * N + 22]);

// Recent events feed
const rawRecent = (results[2 * N + 23] ?? []) as string[];
interface RecentEvent { ts: string; page: string; country: string; city?: string; referrer: string; device: string; utm?: string; }
const recentEvents: RecentEvent[] = rawRecent.map(s => {
  try { return JSON.parse(s) as RecentEvent; } catch { return null; }
}).filter((e): e is RecentEvent => e !== null);

// Sessions & bounce rate
const sessionTotal   = Number(results[2 * N + 24] ?? 0);
const sessionEngaged = Number(results[2 * N + 25] ?? 0);
const bounceRatePct  = sessionTotal > 10
  ? Math.max(0, Math.min(100, Math.round((1 - Math.min(sessionEngaged, sessionTotal) / sessionTotal) * 100)))
  : null;

// Exit pages
const topExitPages = parseZSet(results[2 * N + 26]);

// Core Web Vitals
function parseCwv(raw: unknown) {
  const arr = (raw ?? []) as string[];
  const d: Record<string, number> = {};
  for (let i = 0; i < arr.length; i += 2) d[arr[i]!] = Number(arr[i + 1]);
  const good = d['good'] ?? 0;
  const ni   = d['needs-improvement'] ?? 0;
  const poor = d['poor'] ?? 0;
  return { good, ni, poor, total: good + ni + poor };
}
const cwvLCP = parseCwv(results[2 * N + 27]);
const cwvCLS = parseCwv(results[2 * N + 28]);
const cwvINP = parseCwv(results[2 * N + 29]);

// Active now (visits within last 5 min)
const fiveMinAgo = new Date(Date.now() - 5 * 60 * 1000).toISOString();
const activeNow  = recentEvents.filter(e => e.ts >= fiveMinAgo).length;

// Hourly heatmap — Redis HGETALL returns flat [field, val, field, val, ...]
const rawHourly = (results[2 * N + 17] ?? []) as string[];
const hourlyViews = Array.from({ length: 24 }, (_, h) => {
  const idx = rawHourly.indexOf(String(h));
  return { hour: h, views: idx !== -1 ? Number(rawHourly[idx + 1]) : 0 };
});

// Average time on page (seconds)
const avgTimeSecs = totalTimeSessions > 0 ? Math.round(totalTimeSecs / totalTimeSessions) : 0;
function fmtDuration(secs: number) {
  if (secs < 60) return `${secs}s`;
  return `${Math.floor(secs / 60)}m ${secs % 60}s`;
}

// ─── Milestone progress ───────────────────────────────────────────────────────
const MILESTONES = [100, 250, 500, 1_000, 2_500, 5_000, 10_000, 25_000, 50_000, 100_000];
const nextMilestone = MILESTONES.find(m => m > totalViews) ?? null;
const prevMilestone = nextMilestone
  ? (MILESTONES[MILESTONES.indexOf(nextMilestone) - 1] ?? 0)
  : null;
const milestoneProgress = (nextMilestone && prevMilestone !== null)
  ? Math.min(((totalViews - prevMilestone) / (nextMilestone - prevMilestone)) * 100, 100)
  : 100;

// Peak hour (UTC)
const peakHour = hourlyViews.reduce((best, h) => h.views > best.views ? h : best, hourlyViews[0]!);

// Build scroll funnel — sort by milestone number, compute drop-off %
const scrollFunnel = [25, 50, 75, 100].map(pct => {
  const entry = rawScrollDepth.find(e => Number(e.name) === pct);
  return { pct, count: entry?.count ?? 0 };
});
const totalPageviews = totalViews || 1; // avoid /0

// ─── Computed stats ───────────────────────────────────────────────────────────
const todayViews        = dailyViews[N - 1]!.views;
const yesterdayViews    = dailyViews[N - 2]!.views;
const todayVisitors     = dailyVisitors[N - 1]!.visitors;
const yesterdayVisitors = dailyVisitors[N - 2]!.visitors;
const sevenDayViews     = dailyViews.slice(N - 7).reduce((s, d) => s + d.views, 0);
const lastWeekViews     = dailyViews.slice(N - 14, N - 7).reduce((s, d) => s + d.views, 0);
const thirtyDayViews    = dailyViews.slice(N - 30).reduce((s, d) => s + d.views, 0);
const thirtyDayVisitors = dailyVisitors.slice(N - 30).reduce((s, d) => s + d.visitors, 0);
const sevenDayVisitors  = dailyVisitors.slice(N - 7).reduce((s, d) => s + d.visitors, 0);
const ninetyDayViews    = dailyViews.reduce((s, d) => s + d.views, 0);
const ninetyDayVisitors = dailyVisitors.reduce((s, d) => s + d.visitors, 0);
const dailyAvg          = Math.round(thirtyDayViews / 30);

// Peak day in the 30-day window
const peakDay = dailyViews.reduce((best, d) => d.views > best.views ? d : best, dailyViews[0]!);

// Day-of-week aggregation (0=Sun…6=Sat)
const DOW_LABELS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const dowTotals  = Array(7).fill(0) as number[];
const dowCounts  = Array(7).fill(0) as number[];
dailyViews.forEach(({ date, views }) => {
  const dow = new Date(date + 'T00:00:00Z').getUTCDay();
  dowTotals[dow] += views;
  dowCounts[dow] += 1;
});
const dowAvg = dowTotals.map((total, i) => ({
  label: DOW_LABELS[i]!,
  avg: dowCounts[i]! > 0 ? Math.round(total / dowCounts[i]!) : 0,
}));
const maxDowAvg = Math.max(...dowAvg.map(d => d.avg), 1);

// ─── Week-over-week deltas ────────────────────────────────────────────────────
type Delta = { pct: number; positive: boolean } | null;

function calcDelta(curr: number, prev: number): Delta {
  if (prev === 0) return null;
  const pct = Math.round(((curr - prev) / prev) * 100);
  return { pct, positive: pct >= 0 };
}

const delta7Day    = calcDelta(sevenDayViews, lastWeekViews);
const deltaToday   = calcDelta(todayViews, yesterdayViews);
const deltaVisitor = calcDelta(todayVisitors, yesterdayVisitors);

// Delta display helpers (neutral when pct === 0)
function deltaClass(d: Delta): string {
  if (d === null || d.pct === 0) return 'stat-delta neutral';
  return `stat-delta ${d.positive ? 'pos' : 'neg'}`;
}
function deltaArrow(d: Delta): string {
  if (d === null || d.pct === 0) return '–';
  return d.positive ? '▲' : '▼';
}

// Last-updated timestamp (server render time)
const renderTime = new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZoneName: 'short' });

// First date with pageview data (for all-time sub-label)
const firstDataDate = dailyViews.find(d => d.views > 0)?.date ?? days[0]!;
const firstDataFmt  = new Date(firstDataDate + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

// Views-per-visitor ratio for today and 30-day
const todayVpv      = todayVisitors > 0 ? (todayViews / todayVisitors).toFixed(1) : null;
const thirtyDayVpv  = thirtyDayVisitors > 0 ? (thirtyDayViews / thirtyDayVisitors).toFixed(1) : null;

// Scroll retention — % of 25% readers who reached each deeper milestone
const scroll25 = scrollFunnel[0]!.count || 1;

// ─── Chart helpers ────────────────────────────────────────────────────────────
const max7   = Math.max(...dailyViews.slice(N - 7).map(d => d.views), 1);
const max30  = Math.max(...dailyViews.slice(N - 30).map(d => d.views), 1);
const max90  = Math.max(...dailyViews.map(d => d.views), 1);
const maxV7  = Math.max(...dailyVisitors.slice(N - 7).map(d => d.visitors), 1);
const maxV30 = Math.max(...dailyVisitors.slice(N - 30).map(d => d.visitors), 1);
const maxV90 = Math.max(...dailyVisitors.map(d => d.visitors), 1);
const maxViews    = max30;  // default display is 30d
const maxVisitors = maxV30;
const maxHourly   = Math.max(...hourlyViews.map(h => h.views), 1);
const todayDate   = days[N - 1];

function barH(val: number, max: number) {
  return val > 0 ? Math.max((val / max) * 100, 3).toFixed(1) : '0';
}

function fmtDate(iso: string) {
  const [, m, d] = iso.split('-');
  return `${parseInt(m!)}/${parseInt(d!)}`;
}

function fmtNum(n: number) { return n.toLocaleString('en-US'); }

function flag(code: string): string {
  if (code.length !== 2) return '';
  return String.fromCodePoint(
    0x1F1E6 + code.toUpperCase().charCodeAt(0) - 65,
    0x1F1E6 + code.toUpperCase().charCodeAt(1) - 65,
  );
}

// ─── Per-page scroll depth (second pipeline, after topPages is known) ─────────
const scrollPages = topPages.slice(0, 5).map(p => p.name);
const scrollPageResults = scrollPages.length > 0
  ? await redisPipeline(scrollPages.map(p => ['ZREVRANGE', `page_scroll:${p.slice(0, 150)}`, 0, -1, 'WITHSCORES']))
  : [];
const perPageScroll = scrollPages.map((pg, i) => ({
  page: pg,
  depth: parseZSet(scrollPageResults[i]),
})).filter(p => p.depth.some(d => d.count > 0));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Analytics</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="page">

      <header class="header">
        <a href="/" class="back-link">&larr; jonosmond.com</a>
        <div class="header-row">
          <h1>Analytics</h1>
          <div class="header-actions">
            <button id="export-btn" class="export-btn">Export CSV</button>
            <a href="/analytics" class="refresh" id="refresh-link" onclick="event.preventDefault();this.textContent='Loading\u2026';this.style.pointerEvents='none';location.reload()">Refresh</a>
            <button id="opt-out-btn" class="opt-link"></button>
          </div>
        </div>
        <p class="updated-time">Updated {renderTime}</p>
      </header>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="card card-primary">
          <div class="stat-value">{fmtNum(totalViews)}</div>
          <div class="stat-label">All-time views</div>
          <div class="stat-sub">since {firstDataFmt}</div>
        </div>
        <div class="card card-primary">
          <div class="stat-value">{fmtNum(sevenDayViews)}</div>
          <div class="stat-label">Last 7 days</div>
          {delta7Day && (
            <div class={deltaClass(delta7Day)}>
              {deltaArrow(delta7Day)} {Math.abs(delta7Day.pct)}% vs prev week
            </div>
          )}
        </div>
        <div class="card card-primary">
          <div class="stat-value">{fmtNum(todayViews)}</div>
          <div class="stat-label">Today's views</div>
          {deltaToday && (
            <div class={deltaClass(deltaToday)}>
              {deltaArrow(deltaToday)} {Math.abs(deltaToday.pct)}% vs yesterday
            </div>
          )}
          {todayVpv && <div class="stat-sub">{todayVpv} views/visitor</div>}
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(todayVisitors)}</div>
          <div class="stat-label">Today's visitors</div>
          {deltaVisitor && (
            <div class={deltaClass(deltaVisitor)}>
              {deltaArrow(deltaVisitor)} {Math.abs(deltaVisitor.pct)}% vs yesterday
            </div>
          )}
        </div>
        {avgTimeSecs > 0 && (
          <div class="card">
            <div class="stat-value">{fmtDuration(avgTimeSecs)}</div>
            <div class="stat-label">Avg. time on page</div>
            <div class="stat-sub">{fmtNum(totalTimeSessions)} sessions tracked</div>
          </div>
        )}
        <div class="card">
          <div class="stat-value">{fmtNum(thirtyDayViews)}</div>
          <div class="stat-label">30-day views</div>
          {thirtyDayVpv && <div class="stat-sub">{thirtyDayVpv} views/visitor</div>}
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(dailyAvg)}</div>
          <div class="stat-label">Daily avg (30d)</div>
          {peakDay.views > 0 && (
            <div class="stat-sub">Peak {fmtNum(peakDay.views)} on {fmtDate(peakDay.date)}</div>
          )}
        </div>
        <div class="card">
          <div class="stat-value">{fmtNum(thirtyDayVisitors)}</div>
          <div class="stat-label">~30-day visitors</div>
          <div class="stat-sub"><abbr class="est-tip" title="Sums daily unique visitor counts — may double-count visitors across days">Est. ⓘ</abbr></div>
        </div>
        {nextMilestone !== null && (
          <div class="card milestone-card">
            <div class="milestone-label">Next milestone</div>
            <div class="milestone-target">{fmtNum(nextMilestone)}</div>
            <div class="milestone-bar-bg">
              <div class="milestone-bar-fill" style={`width:${milestoneProgress.toFixed(1)}%`}></div>
            </div>
            <div class="milestone-sub">{fmtNum(nextMilestone - totalViews)} views to go</div>
          </div>
        )}
        {activeNow > 0 && (
          <div class="card">
            <div class="stat-value active-count">{activeNow}</div>
            <div class="stat-label">Active now</div>
            <div class="stat-sub">Visitors in last 5 min</div>
          </div>
        )}
        {bounceRatePct !== null && (
          <div class="card">
            <div class="stat-value">{bounceRatePct}%</div>
            <div class="stat-label">~Bounce rate</div>
            <div class="stat-sub">Est. single-page sessions</div>
          </div>
        )}
      </div>

      <!-- Chart with views / visitors toggle + date range toggle -->
      <div class="card chart-card">
        <div class="chart-header">
          <h2 class="section-title" id="chart-title">Last 30 days</h2>
          <div class="chart-controls">
            <div class="range-control" role="group" aria-label="Date range">
              <button class="range-btn" data-range="7">7d</button>
              <button class="range-btn active" data-range="30">30d</button>
              <button class="range-btn" data-range="90">90d</button>
            </div>
            <span class="ctrl-sep" aria-hidden="true"></span>
            <div class="chart-toggle" role="group" aria-label="Chart metric">
              <button class="toggle-btn active" data-mode="views">Views</button>
              <button class="toggle-btn" data-mode="visitors">Visitors</button>
            </div>
          </div>
        </div>
        <div class="chart" id="chart"
          data-avg-vh={barH(dailyAvg, max30)}
          data-avg-uh={barH(Math.round(thirtyDayVisitors / 30), maxV30)}
          data-avg7-vh={barH(Math.round(sevenDayViews / 7), max7)}
          data-avg7-uh={barH(Math.round(sevenDayVisitors / 7), maxV7)}
          data-avg90-vh={barH(Math.round(ninetyDayViews / 90), max90)}
          data-avg90-uh={barH(Math.round(ninetyDayVisitors / 90), maxV90)}>
          <div class="avg-line" id="avg-line" style={`bottom:${barH(dailyAvg, max30)}%`} title={`30-day avg: ${fmtNum(dailyAvg)} views/day`}></div>
          {dailyViews.map((day, i) => {
            const in7  = i >= N - 7;
            const in30 = i >= N - 30;
            const vh30 = in30 ? barH(day.views, max30) : '0';
            const uh30 = in30 ? barH(dailyVisitors[i]!.visitors, maxV30) : '0';
            const vh7  = in7  ? barH(day.views, max7)  : '0';
            const uh7  = in7  ? barH(dailyVisitors[i]!.visitors, maxV7)  : '0';
            const vh90 = barH(day.views, max90);
            const uh90 = barH(dailyVisitors[i]!.visitors, maxV90);
            // Default display: 30-day
            const showLabel = (in30 && (N - 30 - i) % 5 === 0) || i === N - 1;
            const isToday = day.date === todayDate;
            return (
              <div class="bar-wrap"
                data-vh={vh30}   data-uh={uh30}
                data-vh7={vh7}   data-uh7={uh7}
                data-vh90={vh90} data-uh90={uh90}
                data-vc={day.views}
