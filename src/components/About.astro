---
const focus = [
  'Accessibility',
  'Product UI',
  'Design systems',
  'Front-end development',
];
---

<section class="about">
  <div class="about__inner">
    <span class="about__label">About</span>
    <div class="about__content">
      <p class="about__bio">
        I'm a product-focused interface developer who cares about the
        craft — clear hierarchy, considered interaction, and interfaces that
        feel effortless to use.
      </p>
      <ul class="about__focus" aria-label="Focus areas">
        {focus.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .about {
    padding: clamp(4rem, 8vw, 7rem) clamp(2rem, 6vw, 5rem);
    border-top: 1px solid rgba(245, 244, 240, 0.08);
  }

  .about__inner {
    max-width: 72rem;
    width: 100%;
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .about__inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .about__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding-top: 0.35rem;
  }

  .about__bio {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2.25rem);
    line-height: 1.3;
    color: var(--color-text);
    margin: 0 0 2rem;
  }

  .about__focus {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .about__focus li {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-muted);
    border: 1px solid rgba(245, 244, 240, 0.1);
    border-radius: 100px;
    padding: 0.35rem 0.85rem;
  }
</style>
