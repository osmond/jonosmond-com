---
const building = [
  { label: 'Botanica', note: 'Plant care iOS app (SwiftUI)' },
  { label: 'Wild Tracker', note: 'NHL odds & CLV dashboard' },
  { label: 'jonosmond.com', note: 'This site (Astro + Tailwind)' },
];

const using = [
  'Astro', 'SwiftUI', 'TypeScript', 'Tailwind', 'Vercel',
];

const reading = [
  { title: 'The Design of Everyday Things', author: 'Don Norman' },
  { title: 'Staff Engineer', author: 'Will Larson' },
];
---

<section class="lately">
  <div class="lately__inner">
    <span class="lately__label">Lately</span>
    <div class="lately__content">

      <div class="lately__group">
        <h3 class="lately__group-heading">Building</h3>
        <ul class="lately__list">
          {building.map(({ label, note }) => (
            <li class="lately__item">
              <span class="lately__item-label">{label}</span>
              <span class="lately__item-note">{note}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lately__group">
        <h3 class="lately__group-heading">Using</h3>
        <ul class="lately__tags">
          {using.map((tag) => (
            <li class="lately__tag">{tag}</li>
          ))}
        </ul>
      </div>

    

    </div>
  </div>
</section>

<style>
  .lately {
    padding: clamp(4rem, 8vw, 7rem) clamp(2rem, 6vw, 5rem);
    border-top: 1px solid var(--color-border);
  }

  .lately__inner {
    max-width: 72rem;
    width: 100%;
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .lately__inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .lately__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding-top: 0.35rem;
  }

  .lately__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .lately__group-heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .lately__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lately__item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .lately__item-label {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .lately__item-note {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lately__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .lately__tag {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.35rem 0.85rem;
  }
</style>
