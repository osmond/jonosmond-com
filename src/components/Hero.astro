---
const links = [
  { label: 'Email', href: 'mailto:jonathan.osmond@gmail.com' },
  { label: 'GitHub', href: 'https://github.com/osmond' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/josmond' },
];
---

<section class="hero">
  <canvas class="hero__grain" aria-hidden="true"></canvas>
  <div class="hero__cursor-glow" aria-hidden="true"></div>
  <div class="hero__inner">
    <p class="hero__eyebrow">Interface Developer</p>
    <h1 class="hero__name">Jon<br />Osmond</h1>
    <p class="hero__tagline">
      I build clean, accessible product interfaces<br />
      with a focus on simplicity and reliability.
    </p>
    <p class="hero__time" id="hero-time" aria-live="off"></p>
    <nav class="hero__links" aria-label="Contact links">
      {links.map(({ label, href }) => (
        <a
          href={href}
          class="hero__link"
          {...href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
        >
          {label}
          <svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      ))}
    </nav>
  </div>
</section>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Live local time ───────────────────────────────────────────────────────
  (function () {
    const el = document.getElementById('hero-time') as HTMLElement | null;
    if (!el) return;
    const timeEl: HTMLElement = el;

    const tz = 'America/Chicago';
    const cityLabel = 'Minneapolis';

    function tick() {
      const now = new Date();
      const timeStr = now.toLocaleTimeString('en-US', {
        timeZone: tz,
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      });
      timeEl.textContent = `${cityLabel}\u2002·\u2002${timeStr}`;
    }

    tick();
    const id = setInterval(tick, 1000);
    document.addEventListener('astro:before-swap', () => clearInterval(id), { once: true });
  })();

  // ── Canvas grain ─────────────────────────────────────────────────────────
  (function () {
    const canvas = document.querySelector<HTMLCanvasElement>('.hero__grain');
    if (!canvas) return;

    const ctx = canvas.getContext('2d')!;
    let animId = 0;

    function resize() {
      const hero = canvas!.parentElement!;
      canvas!.width = hero.offsetWidth;
      canvas!.height = hero.offsetHeight;
    }

    function drawGrain() {
      const w = canvas!.width;
      const h = canvas!.height;
      const imageData = ctx.createImageData(w, h);
      const data = imageData.data;
      for (let i = 0; i < data.length; i += 4) {
        const v = (Math.random() * 255) | 0;
        data[i] = v;
        data[i + 1] = v;
        data[i + 2] = v;
        data[i + 3] = 18; // opacity ~7%
      }
      ctx.putImageData(imageData, 0, 0);
      animId = requestAnimationFrame(drawGrain);
    }

    resize();
    // Only animate grain if motion is allowed
    if (!prefersReduced) {
      drawGrain();
    } else {
      drawGrain(); // draw once, then stop
      cancelAnimationFrame(animId);
    }

    const ro = new ResizeObserver(resize);
    ro.observe(canvas.parentElement!);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
    }, { once: true });
  })();

  // Scroll fade
  if (!prefersReduced) {
    const inner = document.querySelector<HTMLElement>('.hero__inner');
    const onScroll = () => {
      if (!inner) return;
      const scrolled = window.scrollY;
      const max = window.innerHeight * 0.65;
      const progress = Math.min(scrolled / max, 1);
      inner.style.opacity = String(1 - progress);
      inner.style.transform = `translateY(${scrolled * 0.12}px)`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    document.addEventListener('astro:before-swap', () =>
      window.removeEventListener('scroll', onScroll)
    );
  }

  // Cursor glow
  if (!prefersReduced) {
    const glow = document.querySelector<HTMLElement>('.hero__cursor-glow');
    const hero = document.querySelector<HTMLElement>('.hero');
    if (glow && hero) {
      const onMove = (e: MouseEvent) => {
        const rect = hero.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        glow.style.setProperty('--gx', `${x}px`);
        glow.style.setProperty('--gy', `${y}px`);
        glow.style.opacity = '1';
      };
      const onLeave = () => { glow.style.opacity = '0'; };
      hero.addEventListener('mousemove', onMove);
      hero.addEventListener('mouseleave', onLeave);
      document.addEventListener('astro:before-swap', () => {
        hero.removeEventListener('mousemove', onMove);
        hero.removeEventListener('mouseleave', onLeave);
      });
    }
  }
</script>

<style>
  .hero {
    position: relative;
    display: grid;
    place-items: start;
    min-height: 100svh;
    padding: clamp(2rem, 6vw, 5rem);
    overflow: hidden;
  }

  .hero__grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0.5;
    z-index: 0;
  }

  .hero__cursor-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196, 107, 75, 0.12) 0%, transparent 65%);
    transform: translate(-50%, -50%);
    left: var(--gx, 50%);
    top: var(--gy, 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease, left 0.1s linear, top 0.1s linear;
    will-change: left, top;
  }

  .hero__inner {
    position: relative;
    max-width: 72rem;
    width: 100%;
    will-change: opacity, transform;
  }

  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.5rem;
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: clamp(5rem, 17vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
    padding-bottom: 0.12em;
    padding-left: 0.05em;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .hero__time {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
    opacity: 0.7;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--color-border-highlight);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .hero__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero__link svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
</style>
