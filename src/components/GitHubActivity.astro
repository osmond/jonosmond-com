---
---

<section class="activity" id="github-activity" hidden>
  <div class="activity__inner">
    <span class="activity__label">Activity</span>
    <ul class="activity__list" id="github-activity-list" aria-label="Recent GitHub activity"></ul>
  </div>
</section>

<script>
  type GitHubEvent = {
    type: 'PushEvent' | 'CreateEvent' | string;
    repo: { name: string };
    payload: {
      ref?: string;
      ref_type?: string;
      commits?: Array<{ message: string }>;
      size?: number;
    };
    created_at: string;
  };

  function relativeTime(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const seconds = Math.floor(diff / 1000);
    if (seconds < 60) return 'just now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    if (days < 30) return `${days} day${days === 1 ? '' : 's'} ago`;
    const months = Math.floor(days / 30);
    if (months < 12) return `${months} month${months === 1 ? '' : 's'} ago`;
    const years = Math.floor(months / 12);
    return `${years} year${years === 1 ? '' : 's'} ago`;
  }

  async function loadActivity() {
    try {
      const res = await fetch('https://api.github.com/users/osmond/events/public');
      if (!res.ok) return;

      const events = (await res.json()) as GitHubEvent[];

      const filtered = events
        .filter(e => e.type === 'PushEvent' || e.type === 'CreateEvent')
        .slice(0, 5);

      if (filtered.length === 0) return;

      const list = document.getElementById('github-activity-list');
      const section = document.getElementById('github-activity');
      if (!list || !section) return;

      const items = filtered.map((event, index) => {
        const repoFull = event.repo.name;
        const repoShort = repoFull.replace(/^osmond\//, '');
        const time = relativeTime(event.created_at);

        const li = document.createElement('li');
        li.className = 'activity__item';
        li.style.setProperty('--i', String(index));

        // — headline row —
        const headline = document.createElement('div');
        headline.className = 'activity__headline';

        // — meta row —
        const meta = document.createElement('div');
        meta.className = 'activity__meta';

        const repoLink = document.createElement('a');
        repoLink.className = 'activity__repo';
        repoLink.href = `https://github.com/${repoFull}`;
        repoLink.target = '_blank';
        repoLink.rel = 'noopener noreferrer';
        repoLink.textContent = repoShort;

        const timeSpan = document.createElement('span');
        timeSpan.className = 'activity__time';
        timeSpan.textContent = time;

        meta.appendChild(repoLink);
        meta.appendChild(document.createTextNode('\u00a0·\u00a0'));
        meta.appendChild(timeSpan);

        if (event.type === 'PushEvent') {
          const commits = event.payload.commits;
          const rawMessage = commits && commits.length > 0 && commits[0].message.trim()
            ? commits[0].message.trim()
            : null;

          // Fallback to branch name from ref (e.g. refs/heads/main → main)
          const branch = event.payload.ref
            ? event.payload.ref.replace(/^refs\/heads\//, '')
            : null;

          const msgSpan = document.createElement('span');
          msgSpan.className = 'activity__message';

          if (rawMessage) {
            msgSpan.textContent = rawMessage.split('\n')[0];
          } else if (branch) {
            msgSpan.textContent = `pushed to ${branch}`;
          } else {
            msgSpan.textContent = 'pushed';
          }

          // Extra commit count badge
          const count = event.payload.size ?? (commits?.length ?? 0);
          if (count > 1) {
            const badge = document.createElement('span');
            badge.className = 'activity__badge';
            badge.textContent = `+${count - 1}`;
            headline.appendChild(msgSpan);
            headline.appendChild(badge);
          } else {
            headline.appendChild(msgSpan);
          }
        } else {
          // CreateEvent
          const refType = event.payload.ref_type ?? 'repository';
          const ref = event.payload.ref;

          const msgSpan = document.createElement('span');
          msgSpan.className = 'activity__message';
          msgSpan.textContent = ref && refType !== 'repository'
            ? `created ${refType} ${ref}`
            : 'created repository';

          headline.appendChild(msgSpan);
        }

        li.appendChild(headline);
        li.appendChild(meta);

        return li;
      });

      list.replaceChildren(...items);
      section.hidden = false;
    } catch {
      // fail silently
    }
  }

  loadActivity();
</script>

<style>
  .activity {
    padding: clamp(4rem, 8vw, 7rem) clamp(2rem, 6vw, 5rem);
    border-top: 1px solid var(--color-border);
  }

  .activity__inner {
    max-width: 72rem;
    width: 100%;
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .activity__inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .activity__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding-top: 0.35rem;
  }

  .activity__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @keyframes activity-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .activity__item {
    padding: 0.75rem 0.75rem 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    cursor: default;
    border-radius: 6px;
    transition: background 0.2s;
    animation: activity-in 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--i, 0) * 60ms + 80ms);

    /* reset padding-right to bleed hover bg edge to edge */
    margin-left: -0.75rem;
    padding-left: 0.75rem;
    margin-right: -0.75rem;
    padding-right: 0.75rem;
  }

  .activity__item:last-child {
    border-bottom: none;
  }

  .activity__item:hover {
    background: rgba(196, 107, 75, 0.05);
    border-bottom-color: transparent;
  }

  .activity__item:hover + .activity__item {
    border-top-color: transparent;
  }

  .activity__headline {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    overflow: hidden;
  }

  .activity__message {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .activity__badge {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-accent);
    border: 1px solid rgba(196, 107, 75, 0.35);
    border-radius: 100px;
    padding: 0.1em 0.5em;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: 1.6;
  }

  .activity__meta {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-top: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .activity__repo {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .activity__repo:hover {
    color: var(--color-text);
  }

  .activity__time {
    color: var(--color-muted);
  }
</style>
