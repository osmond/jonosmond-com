---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jon Osmond — Interface Developer',
  description = 'I build clean, accessible product interfaces with a focus on simplicity and reliability.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://jonosmond.com');
const ogImage = new URL('/og.svg', Astro.site ?? 'https://jonosmond.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      // Don't track: analytics page itself, or opted-out visitors
      const isAnalytics = window.location.pathname.startsWith('/analytics');
      const isOptedOut  = localStorage.getItem('analytics_opt_out') === '1';
      if (!isAnalytics && !isOptedOut) {
        const w = window.innerWidth;
        const payload = JSON.stringify({
          page: window.location.pathname,
          referrer: document.referrer,
          colorScheme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'Dark' : 'Light',
          viewport: w < 768 ? 'Mobile' : w < 1024 ? 'Tablet' : 'Desktop',
        });
        if (typeof navigator.sendBeacon === 'function') {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
        } else {
          fetch('/api/track', {
            method: 'POST',
            body: payload,
            headers: { 'Content-Type': 'application/json' },
            keepalive: true,
          }).catch(() => {});
        }
      }
    </script>
  </body>
</html>
