---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jon Osmond — Interface Developer',
  description = 'I build clean, accessible product interfaces with a focus on simplicity and reliability.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://jonosmond.com');
const ogImage = new URL('/og.svg', Astro.site ?? 'https://jonosmond.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      // Don't track: analytics page itself, or opted-out visitors
      const isAnalytics = window.location.pathname.startsWith('/analytics');
      const isOptedOut  = localStorage.getItem('analytics_opt_out') === '1';

      function sendEvent(body: object) {
        const blob = new Blob([JSON.stringify(body)], { type: 'application/json' });
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/event', blob);
        } else {
          fetch('/api/event', { method: 'POST', body: JSON.stringify(body), headers: { 'Content-Type': 'application/json' }, keepalive: true }).catch(() => {});
        }
      }

      if (!isAnalytics && !isOptedOut) {
        const page = window.location.pathname;
        const w = window.innerWidth;

        // new vs. returning: use localStorage to distinguish first-ever visit
        const HAS_VISITED_KEY = 'analytics_visited';
        const isNew = !localStorage.getItem(HAS_VISITED_KEY);
        localStorage.setItem(HAS_VISITED_KEY, '1');

        // Entry page: no referrer, or referrer is external
        const isEntry = !document.referrer || !document.referrer.includes('jonosmond.com');

        // UTM parameters
        const sp = new URLSearchParams(location.search);
        const utmSource   = sp.get('utm_source')   ?? '';
        const utmMedium   = sp.get('utm_medium')   ?? '';
        const utmCampaign = sp.get('utm_campaign') ?? '';

        const payload = JSON.stringify({
          page,
          referrer: document.referrer,
          colorScheme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'Dark' : 'Light',
          viewport: w < 768 ? 'Mobile' : w < 1024 ? 'Tablet' : 'Desktop',
          isNew,
          isEntry,
          language: navigator.language ?? '',
          utmSource,
          utmMedium,
          utmCampaign,
        });
        if (typeof navigator.sendBeacon === 'function') {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
        } else {
          fetch('/api/track', {
            method: 'POST',
            body: payload,
            headers: { 'Content-Type': 'application/json' },
            keepalive: true,
          }).catch(() => {});
        }

        // ── Time on page ───────────────────────────────────────────────────
        const pageStartTime = Date.now();
        let durationSent = false;
        function sendDuration() {
          if (durationSent) return;
          durationSent = true;
          const secs = Math.round((Date.now() - pageStartTime) / 1000);
          if (secs < 1) return;
          sendEvent({ type: 'duration', value: String(secs), page });
        }
        // ── Exit page tracking ─────────────────────────────────────────────
        let exitSent = false;
        function sendExit() {
          if (exitSent) return;
          exitSent = true;
          sendEvent({ type: 'exit', page });
        }
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') { sendDuration(); sendExit(); }
        });
        window.addEventListener('pagehide', () => { sendDuration(); sendExit(); });

        // ── Scroll depth tracking ──────────────────────────────────────────
        // Fire once per milestone (25 / 50 / 75 / 100) per page view
        const milestones = [25, 50, 75, 100];
        const reached = new Set<number>();
        function checkScroll() {
          const scrolled = window.scrollY + window.innerHeight;
          const total    = document.documentElement.scrollHeight;
          const pct      = total <= window.innerHeight ? 100 : Math.floor((scrolled / total) * 100);
          for (const m of milestones) {
            if (pct >= m && !reached.has(m)) {
              reached.add(m);
              sendEvent({ type: 'scroll', value: String(m), page });
            }
          }
        }
        checkScroll(); // check immediately (catches 100% on short pages)
        window.addEventListener('scroll', checkScroll, { passive: true });

        // ── Outbound click tracking ────────────────────────────────────────
        document.addEventListener('click', (e) => {
          const target = (e.target as Element).closest('a');
          if (!target) return;
          const href = target.getAttribute('href') ?? '';
          if (!href.startsWith('http')) return; // internal links & anchors
          try {
            const host = new URL(href).hostname.replace(/^www\./, '');
            if (!host.endsWith('jonosmond.com')) {
              sendEvent({ type: 'click', value: host, page });
            }
          } catch { /* ignore malformed hrefs */ }
        });
      }
    </script>
    <script>
      // ── Core Web Vitals ────────────────────────────────────────────────────
      import { onLCP, onCLS, onINP } from 'web-vitals';
      const _isAnalytics = window.location.pathname.startsWith('/analytics');
      const _isOptedOut  = localStorage.getItem('analytics_opt_out') === '1';
      if (!_isAnalytics && !_isOptedOut) {
        function rateMetric(name: string, value: number): string {
          if (name === 'LCP') return value <= 2500 ? 'good' : value <= 4000 ? 'needs-improvement' : 'poor';
          if (name === 'CLS') return value <= 0.1  ? 'good' : value <= 0.25  ? 'needs-improvement' : 'poor';
          if (name === 'INP') return value <= 200  ? 'good' : value <= 500   ? 'needs-improvement' : 'poor';
          return 'poor';
        }
        function reportVital(m: { name: string; value: number }) {
          const body = JSON.stringify({
            type: 'vitals',
            metric: m.name,
            rating: rateMetric(m.name, m.value),
            page: window.location.pathname,
          });
          navigator.sendBeacon?.('/api/event', new Blob([body], { type: 'application/json' }));
        }
        onLCP(reportVital);
        onCLS(reportVital);
        onINP(reportVital);
      }
    </script>
  </body>
</html>
